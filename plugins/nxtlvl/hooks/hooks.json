{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill|Task",
        "hooks": [
          { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/fallback-log.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}\"/hooks/context-alert.js", "timeout": 10 }
        ],
        "description": "Alert the agent once live context crosses NXTLVL_CONTEXT_ALERT_TOKENS (default 180k)",
        "id": "post:context-alert"
      }
    ]
  }
}
